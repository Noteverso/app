<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.noteverso.core.dao.ViewOptionMapper">
    <select id="batchSelectByObjectIds" resultType="com.noteverso.core.model.entity.ViewOption">
        SELECT * FROM noteverso_view_option
        <where>
            <if test="objectIds != null and objectIds.size() > 0">
                object_id IN
                <foreach collection="objectIds" item="object" open="(" close=")" separator=",">
                    #{object}
                </foreach>
            </if>
            <if test="objectIds == null or objectIds.size() == 0">
                AND 1 = 0
            </if>
            AND creator = #{userId}
        </where>
    </select>
</mapper>
