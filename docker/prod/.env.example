# Production Environment Configuration
# IMPORTANT: Change all passwords and secrets before deploying to production!

# Database
DATABASE_HOST_PORT=localhost:5432
DATABASE_DB=noteverso_prod
DATABASE_USERNAME=noteverso_prod
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# PostgreSQL Docker
POSTGRES_DB=noteverso_prod
POSTGRES_USER=noteverso_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# Mail (Mailpit - replace with real SMTP in production)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
SMTP_AUTH=username:password

# MinIO (S3-compatible storage)
OSS_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
OSS_ACCESS_KEY_SECRET=CHANGE_ME_MINIO_SECRET_KEY
OSS_END_POINT=http://localhost:9000
OSS_BUCKET_NAME=noteverso-prod
OSS_IS_HTTPS=N

# MinIO Docker
MINIO_ROOT_USER=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET_KEY

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_MIN_256_BITS_REQUIRED
JWT_EXPIRATION_DAYS=30

# Application
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
