# Development Environment Configuration (Docker)
# This file is used when running the full stack in Docker containers

# Database (use service name for Docker networking)
DATABASE_HOST_PORT=postgres:5432
DATABASE_DB=noteverso_dev
DATABASE_USERNAME=noteverso
DATABASE_PASSWORD=noteverso_dev_pass

# Redis (use service name for Docker networking)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=noteverso_redis_dev

# Mail (Mailpit - use service name for Docker networking)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# MinIO (S3-compatible storage - use service name for Docker networking)
OSS_ACCESS_KEY=noteverso_minio
OSS_ACCESS_KEY_SECRET=noteverso_minio_dev_pass
OSS_END_POINT=http://minio:9000
OSS_BUCKET_NAME=noteverso-dev
OSS_IS_HTTPS=N

# JWT
JWT_SECRET=dev_secret_key_change_in_production_min_256_bits_required_for_hs256_algorithm
JWT_EXPIRATION_DAYS=30

# Application
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
